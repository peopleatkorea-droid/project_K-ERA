# Copy this file to .env.local for local development.
# Do not commit .env.local.

# Auth / app
KERA_API_SECRET=replace-with-random-secret
KERA_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Database / storage
KERA_CONTROL_PLANE_DATABASE_URL=
KERA_CONTROL_PLANE_ARTIFACT_DIR=
KERA_DATA_PLANE_DATABASE_URL=
KERA_STORAGE_DIR=
KERA_DATABASE_URL=
DATABASE_URL=

# HIRA institution directory
KERA_HIRA_API_KEY=
KERA_HIRA_HOSPITAL_INFO_URL=https://apis.data.go.kr/B551182/hospInfoServicev2/getHospBasisList
KERA_HIRA_API_TIMEOUT_SECONDS=30

# Segmentation
MEDSAM_SCRIPT=
MEDSAM_CHECKPOINT=

# AI Clinic LLM
# Server-side only. Do not use NEXT_PUBLIC_ for API keys.
KERA_AI_CLINIC_OPENAI_API_KEY=
KERA_AI_CLINIC_LLM_MODEL=gpt-4o-mini
KERA_AI_CLINIC_LLM_BASE_URL=https://api.openai.com/v1/responses
KERA_AI_CLINIC_LLM_TIMEOUT_SECONDS=45

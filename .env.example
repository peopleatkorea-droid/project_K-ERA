# Copy this file to .env.local for local development.
# Do not commit .env.local.

# Auth / app
KERA_API_SECRET=replace-with-random-secret
KERA_LOCAL_API_JWT_PRIVATE_KEY_B64=
KERA_LOCAL_API_JWT_PUBLIC_KEY_B64=
KERA_LOCAL_API_JWT_ISSUER=kera-control-plane
KERA_LOCAL_API_JWT_AUDIENCE=kera-platform
KERA_GOOGLE_CLIENT_ID=
KERA_GOOGLE_DESKTOP_CLIENT_ID=
KERA_GOOGLE_DESKTOP_CLIENT_SECRET=
KERA_GOOGLE_CLIENT_IDS=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_DESKTOP_CLIENT_ID=
NEXT_PUBLIC_API_BASE_URL=
KERA_INTERNAL_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_LOCAL_NODE_API_BASE_URL=http://127.0.0.1:8000
KERA_CONTROL_PLANE_SESSION_SECRET=
KERA_CONTROL_PLANE_ADMIN_EMAILS=
KERA_CONTROL_PLANE_DEV_AUTH=true
NEXT_PUBLIC_CONTROL_PLANE_BASE_PATH=/control-plane/api

# Database / storage
KERA_CONTROL_PLANE_DATABASE_URL=
KERA_CONTROL_PLANE_DIR=
KERA_CONTROL_PLANE_ARTIFACT_DIR=
KERA_DATA_PLANE_DATABASE_URL=
KERA_STORAGE_DIR=
KERA_MODEL_DIR=
KERA_MODEL_SOURCE_PROVIDER=local
KERA_MODEL_AUTO_DOWNLOAD=true
KERA_MODEL_KEEP_VERSIONS=2
KERA_MODEL_DOWNLOAD_TIMEOUT_SECONDS=300
KERA_MODEL_DISTRIBUTION_MODE=local_path
KERA_DATABASE_URL=
DATABASE_URL=
KERA_CONTROL_PLANE_API_BASE_URL=http://127.0.0.1:3000/control-plane/api
KERA_CONTROL_PLANE_NODE_ID=
KERA_CONTROL_PLANE_NODE_TOKEN=
KERA_CONTROL_PLANE_API_TIMEOUT_SECONDS=30
KERA_CONTROL_PLANE_HEARTBEAT_INTERVAL_SECONDS=300
KERA_CONTROL_PLANE_BOOTSTRAP_REFRESH_SECONDS=900
KERA_SITE_STORAGE_SOURCE=local

# HIRA institution directory
KERA_HIRA_API_KEY=
KERA_HIRA_HOSPITAL_INFO_URL=https://apis.data.go.kr/B551182/hospInfoServicev2/getHospBasisList
KERA_HIRA_API_TIMEOUT_SECONDS=30

# Segmentation
MEDSAM_SCRIPT=
MEDSAM_CHECKPOINT=

# AI Clinic LLM
# Server-side only. Do not use NEXT_PUBLIC_ for API keys.
KERA_AI_CLINIC_OPENAI_API_KEY=
KERA_AI_CLINIC_LLM_MODEL=gpt-4o-mini
KERA_AI_CLINIC_LLM_BASE_URL=https://api.openai.com/v1/responses
KERA_AI_CLINIC_LLM_TIMEOUT_SECONDS=45

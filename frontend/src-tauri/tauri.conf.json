{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "K-ERA Desktop",
  "version": "1.0.0",
  "identifier": "com.kera.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run desktop:bundle",
    "devUrl": "http://127.0.0.1:3000",
    "frontendDist": "../desktop-dist"
  },
  "app": {
    "security": {
      "csp": "default-src 'self' asset: data: blob: http://asset.localhost https://asset.localhost; img-src 'self' asset: data: blob: http://127.0.0.1:* http://localhost:* http://asset.localhost https://asset.localhost https:; media-src 'self' asset: data: blob: http://127.0.0.1:* http://localhost:* http://asset.localhost https://asset.localhost https:; font-src 'self' asset: data: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' https://accounts.google.com; connect-src 'self' asset: data: blob: http://127.0.0.1:* http://localhost:* http://asset.localhost https://asset.localhost https: ws: wss:; frame-src 'self' https://accounts.google.com; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; form-action 'self' https://accounts.google.com",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "$APPDATA/**",
          "$APPLOCALDATA/**",
          "$APPCACHE/**",
          "$TEMP/**"
        ]
      }
    },
    "windows": [
      {
        "label": "main",
        "title": "K-ERA Desktop",
        "width": 1600,
        "height": 1000,
        "maximized": true,
        "resizable": true,
        "dragDropEnabled": false
      }
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/peopleatkorea-droid/project_K-ERA/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdBOEJDMENFQTRGNjhCNDUKUldSRmkvYWt6c0NMZWpEZE1OSnd2amFtZ1E5S0h4TmNQRjlMZE9nVy9acmRhcXg3SG0zTkFYUU0K",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "nsis",
      "msi"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "installer-hooks.nsh"
      },
      "wix": {
        "bannerPath": "wix/banner-cpu-footprint.bmp",
        "dialogImagePath": "wix/dialog-cpu-footprint.bmp"
      }
    },
    "icon": [
      "icons/icon.ico"
    ],
    "resources": {
      "../.desktop-runtime-bundle/python-runtime.zip": "python-runtime.zip",
      "../../app.py": "backend/app.py",
      "../../src": "backend/src",
      "../../MedSAM-main": "backend/MedSAM-main"
    }
  }
}

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "K-ERA Desktop",
  "version": "1.0.0",
  "identifier": "com.kera.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run desktop:bundle",
    "devUrl": "http://127.0.0.1:3000",
    "frontendDist": "../desktop-dist"
  },
  "app": {
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "$APPDATA/**",
          "$APPLOCALDATA/**",
          "$APPCACHE/**",
          "$TEMP/**"
        ]
      }
    },
    "windows": [
      {
        "label": "main",
        "title": "K-ERA Desktop",
        "width": 1600,
        "height": 1000,
        "resizable": true
      }
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/peopleatkorea-droid/project_K-ERA/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUyMUJBMjQ4OTlENUEzNEQKUldSTm85V1pTS0liNGhhRFZoQjZTS09DUlNKa2pzMVY0Y1JGd041dzRkOHpxRTROMU9rQVZOWWQK"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi"
    ],
    "icon": [
      "icons/icon.ico"
    ],
    "resources": {
      "../.desktop-runtime/python-runtime": "python-runtime",
      "../../app.py": "backend/app.py",
      "../../src": "backend/src",
      "../../MedSAM-main": "backend/MedSAM-main"
    }
  }
}

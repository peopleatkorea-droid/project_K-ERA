{
  "name": "kera-web",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "clean": "node ./scripts/prepare-dev.mjs --clean-only",
    "dev": "node ./scripts/run-next-command.mjs dev --hostname 0.0.0.0 --port 3000",
    "dev:clean": "node ./scripts/run-next-command.mjs dev --clean --hostname 0.0.0.0 --port 3000",
    "desktop:prepare-runtime": "node ./scripts/prepare-embedded-python.mjs",
    "desktop:build": "node ./scripts/build-desktop-shell.mjs",
    "desktop:bundle": "npm run desktop:prepare-runtime && npm run desktop:build",
    "desktop:verify": "node ./scripts/verify-desktop-runtime.mjs",
    "desktop:smoke": "node ./scripts/run-desktop-smoke.mjs",
    "desktop:smoke-installed": "powershell -ExecutionPolicy Bypass -File ./scripts/run-installed-desktop-smoke.ps1",
    "desktop:verify-package": "node ./scripts/verify-tauri-package.mjs",
    "desktop:package": "npm run tauri:build && npm run desktop:verify-package",
    "build": "node ./scripts/run-next-command.mjs build",
    "rebuild": "npm run clean && next build",
    "start": "node ./scripts/run-next-command.mjs start",
    "tauri:dev": "node ./scripts/run-tauri-dev.mjs",
    "tauri:build": "node ./scripts/run-tauri-build.mjs",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.23",
    "@tauri-apps/api": "^2.10.1",
    "google-auth-library": "^10.1.0",
    "jose": "^6.1.0",
    "next": "^15.2.0",
    "postgres": "^3.4.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.13.9",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "esbuild": "^0.27.4",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}

{
  "name": "kera-web",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "clean": "node ./scripts/prepare-dev.mjs --clean-only",
    "dev": "node ./scripts/prepare-dev.mjs --port 3000 && next dev --hostname 0.0.0.0 --port 3000",
    "dev:clean": "node ./scripts/prepare-dev.mjs --port 3000 --clean && next dev --hostname 0.0.0.0 --port 3000",
    "build": "next build",
    "rebuild": "npm run clean && next build",
    "start": "next start",
    "tauri:dev": "node ./scripts/run-tauri-dev.mjs",
    "tauri:build": "tauri build",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "google-auth-library": "^10.1.0",
    "jose": "^6.1.0",
    "next": "^15.2.0",
    "postgres": "^3.4.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^22.13.9",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
